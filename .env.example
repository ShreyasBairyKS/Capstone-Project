# ============================================================
# VisionFood QAI — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# --- Deployment Tier ---
TIER=edge
DEVICE_ID=edge_node_01

# --- Model Paths ---
YOLOV11_ONNX_PATH=models/yolov11n_best.onnx
EFFICIENTVIT_ONNX_PATH=models/efficientvit_m5_best.onnx

# --- Inference Thresholds ---
YOLOV11_CONF_THRESHOLD=0.40
YOLOV11_IOU_THRESHOLD=0.45
CONFIRMED_DEFECT_THRESHOLD=0.85
ESCALATE_THRESHOLD=0.60
HUMAN_REVIEW_THRESHOLD=0.45

# --- Camera ---
CAMERA_INDEX=0
CAMERA_MODE=software

# --- SQLite (development) / PostgreSQL (production) ---
# SQLite auto-creates the file on first startup — no setup needed for dev
DATABASE_URL=sqlite:///./visionfood_dev.db
# Production (uncomment and fill):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/visionfood

# --- MongoDB (Motor async — Products & Production Runs) ---
# Local MongoDB (default — ensure MongoDB service is running on port 27017)
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=visionfood
# MongoDB Atlas (cloud — uncomment and replace with your connection string):
# MONGO_URL=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB_NAME=visionfood

# --- Redis (live WebSocket stream — needed for the Live tab) ---
REDIS_URL=redis://localhost:6379
REDIS_LIVE_STREAM=inspections:live
REDIS_STREAM_MAX_LEN=1000

# --- API Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must match VITE_API_KEY in dashboard/.env
API_KEY=dev-insecure-key

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_PATH=logs/audit.jsonl

# --- REMEDY Engine ---
REMEDY_ENABLED=true
REMEDY_MAX_ATTEMPTS=2

# --- SKU Profiles Directory ---
SKU_PROFILES_DIR=configs/sku_profiles

# --- Experiment Tracking (optional — leave blank if not using) ---
# W&B: get your key from https://wandb.ai/authorize
WANDB_API_KEY=
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Roboflow (dataset download — optional) ---
ROBOFLOW_API_KEY=
ROBOFLOW_PROJECT_ID=visionfood-defects
ROBOFLOW_VERSION=1
