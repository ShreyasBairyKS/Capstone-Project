# ============================================================
# VisionFood QAI — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# --- Deployment Tier ---
TIER=edge
DEVICE_ID=edge_node_01

# --- Model Paths ---
YOLOV11_ONNX_PATH=models/yolov11n_best.onnx
EFFICIENTVIT_ONNX_PATH=models/efficientvit_m5_best.onnx

# --- Inference Thresholds ---
YOLOV11_CONF_THRESHOLD=0.40
YOLOV11_IOU_THRESHOLD=0.45
AUTO_PASS_THRESHOLD=0.85
ESCALATE_THRESHOLD=0.60
HUMAN_REVIEW_THRESHOLD=0.45

# --- Camera ---
CAMERA_INDEX=0
CAMERA_MODE=software

# --- Database ---
# Development (SQLite — no server required)
DATABASE_URL=sqlite+aiosqlite:///./visionfood_dev.db
# Production (PostgreSQL — set this in prod environment)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/visionfood

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=REPLACE_WITH_GENERATED_KEY

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- REMEDY Engine ---
REMEDY_ENABLED=true

# --- Experiment Tracking ---
# W&B — get your key from https://wandb.ai/authorize
WANDB_API_KEY=REPLACE_WITH_WANDB_KEY

# --- Roboflow (dataset download) ---
ROBOFLOW_API_KEY=REPLACE_WITH_ROBOFLOW_KEY
ROBOFLOW_PROJECT_ID=visionfood-defects
ROBOFLOW_VERSION=1
