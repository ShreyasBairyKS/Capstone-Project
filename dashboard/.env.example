# ============================================================
# VisionFood QAI — Frontend Environment Variables (Vite)
# Copy this file to .env and fill in values.
# Variables MUST be prefixed with VITE_ to be accessible in browser code.
# NEVER commit .env to version control.
# ============================================================

# Vite dev server proxies /api/* → http://localhost:8000/*
# Leave as /api for local development.
# In production (deployed), set this to the full API URL:
# VITE_API_BASE=https://your-api-domain.com
VITE_API_BASE=/api

# API key sent as X-API-Key header on every request.
# MUST exactly match the API_KEY value in the backend .env file.
VITE_API_KEY=dev-insecure-key

# WebSocket URL for the live inspection feed (Live tab).
# The Vite proxy forwards /ws/* to ws://localhost:8000/ws/*
VITE_WS_URL=ws://localhost:8000/ws/live
